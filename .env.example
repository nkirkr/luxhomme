# ============================================
# SITE CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Site"

# Site type hint (informational only, does not affect logic)
# landing | corporate | ecommerce
SITE_TYPE=landing

# ============================================
# FEATURE FLAGS — Modules
# ============================================
NEXT_PUBLIC_FEATURE_BLOG=false
NEXT_PUBLIC_FEATURE_AUTH=false
NEXT_PUBLIC_FEATURE_DASHBOARD=false
NEXT_PUBLIC_FEATURE_SHOP=false
NEXT_PUBLIC_FEATURE_CHAT=false
NEXT_PUBLIC_FEATURE_PAYMENT=false
NEXT_PUBLIC_FEATURE_I18N=false

# ============================================
# CMS CONFIGURATION
# ============================================
# none | wordpress | payload
CMS_PROVIDER=none

# WordPress (WPGraphQL)
WORDPRESS_GRAPHQL_URL=
WP_APPLICATION_USER=
WP_APPLICATION_PASSWORD=
WP_PREVIEW_SECRET=

# Payload CMS
PAYLOAD_API_URL=
PAYLOAD_API_KEY=

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# PAYMENT
# ============================================
# stripe | yookassa | none
PAYMENT_PROVIDER=none

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ============================================
# CHAT
# ============================================
# intercom | tawkto | custom | none
CHAT_PROVIDER=none
CHAT_API_KEY=

# ============================================
# REVALIDATION
# ============================================
REVALIDATION_SECRET=

# ============================================
# I18N
# ============================================
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_LOCALES=en,ru
