# ============================================
# SITE CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Site"

# Site type hint (informational only, does not affect logic)
# landing | corporate | ecommerce
SITE_TYPE=landing

# ============================================
# FEATURE FLAGS — Modules
# ============================================
NEXT_PUBLIC_FEATURE_BLOG=false
NEXT_PUBLIC_FEATURE_AUTH=false
NEXT_PUBLIC_FEATURE_DASHBOARD=false
NEXT_PUBLIC_FEATURE_SHOP=false
NEXT_PUBLIC_FEATURE_CHAT=false
NEXT_PUBLIC_FEATURE_PAYMENT=false
NEXT_PUBLIC_FEATURE_I18N=false

# ============================================
# CMS CONFIGURATION
# ============================================
# none | wordpress | payload
CMS_PROVIDER=none

# WordPress (WPGraphQL)
WORDPRESS_GRAPHQL_URL=
WP_APPLICATION_USER=
WP_APPLICATION_PASSWORD=
WP_PREVIEW_SECRET=

# Payload CMS
PAYLOAD_API_URL=
PAYLOAD_API_KEY=

# ============================================
# SHOP (WooCommerce REST API)
# ============================================
# none | woocommerce
SHOP_PROVIDER=none
# WordPress site root (no trailing path), e.g. https://shop.example.com
WOOCOMMERCE_URL=
# WooCommerce → Settings → Advanced → REST API (Consumer key / secret)
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
# ISO 4217 code for price formatting, e.g. RUB, USD, EUR
WOOCOMMERCE_CURRENCY=RUB
# true = log raw WooCommerce JSON and mapped Product in the terminal (npm run dev)
WOOCOMMERCE_DEBUG_LOG=false

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=

# Redis (optional, for distributed rate limiting)
# If not set, in-memory rate limiting is used (fine for single-instance)
REDIS_URL=

# Logging
# debug | info | warn | error (default: debug in dev, info in production)
LOG_LEVEL=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# PAYMENT
# ============================================
# stripe | yookassa | none
PAYMENT_PROVIDER=none

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ============================================
# CHAT
# ============================================
# intercom | tawkto | custom | none
CHAT_PROVIDER=none
CHAT_API_KEY=

# Tawk.to
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=
NEXT_PUBLIC_TAWKTO_WIDGET_ID=default

# Intercom
NEXT_PUBLIC_INTERCOM_APP_ID=

# ============================================
# EMAIL
# ============================================
# resend | none
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# ============================================
# ANALYTICS
# ============================================
NEXT_PUBLIC_FEATURE_ANALYTICS=false
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=

# ============================================
# REVALIDATION
# ============================================
REVALIDATION_SECRET=

# ============================================
# I18N
# ============================================
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_LOCALES=en,ru
