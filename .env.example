# ============================================
# SITE CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Site"

# Site type hint (informational only, does not affect logic)
# landing | corporate | ecommerce
SITE_TYPE=landing

# ============================================
# FEATURE FLAGS — Modules
# ============================================
NEXT_PUBLIC_FEATURE_BLOG=false
NEXT_PUBLIC_FEATURE_AUTH=false
NEXT_PUBLIC_FEATURE_DASHBOARD=false
NEXT_PUBLIC_FEATURE_SHOP=false
NEXT_PUBLIC_FEATURE_CHAT=false
NEXT_PUBLIC_FEATURE_PAYMENT=false
NEXT_PUBLIC_FEATURE_I18N=false

# ============================================
# CMS CONFIGURATION
# ============================================
# none | wordpress | payload
CMS_PROVIDER=none

# WordPress — REST (записи: /wp-json/wp/v2/posts). Если пусто, берётся WOOCOMMERCE_URL или origin из GRAPHQL ниже.
WORDPRESS_REST_URL=

# Slug страницы «О нас» в WP для REST (по умолчанию about — как на luxhomme.store/about/)
WORDPRESS_ABOUT_PAGE_SLUG=about

# Slug страницы «Контакты» в WP (у вас может быть contacts при URL сайта /contact/)
WORDPRESS_CONTACT_PAGE_SLUG=contacts

# Yandex Maps JS API v3 — ключ из кабинета «Яндекс JavaScript API и HTTP Геокодер».
# Экспонируется в клиент (NEXT_PUBLIC_). Домен должен быть разрешён в настройках ключа.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# WordPress (WPGraphQL)
WORDPRESS_GRAPHQL_URL=
WP_APPLICATION_USER=
WP_APPLICATION_PASSWORD=
WP_PREVIEW_SECRET=

# Payload CMS
PAYLOAD_API_URL=
PAYLOAD_API_KEY=

# ============================================
# SHOP (WooCommerce REST API)
# ============================================
# none | woocommerce
SHOP_PROVIDER=none
# WordPress site root (no trailing path), e.g. https://shop.example.com
WOOCOMMERCE_URL=
# WooCommerce → Settings → Advanced → REST API (Consumer key / secret)
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
# ISO 4217 code for price formatting, e.g. RUB, USD, EUR
WOOCOMMERCE_CURRENCY=RUB
# true = log raw WooCommerce JSON and mapped Product in the terminal (npm run dev)
WOOCOMMERCE_DEBUG_LOG=false

# DaData — подсказки по адресу на checkout (только сервер: /api/dadata/suggest)
# Ключи из кабинета dadata.ru → API-ключи
DADATA_API_KEY=
DADATA_SECRET_KEY=

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# SQLite для Better Auth: пусто или file:./auth.db → файл auth.db в корне репозитория. Иначе file:./путь/к.db
DATABASE_URL=

# Redis (optional, for distributed rate limiting)
# If not set, in-memory rate limiting is used (fine for single-instance)
REDIS_URL=

# Logging
# debug | info | warn | error (default: debug in dev, info in production)
LOG_LEVEL=

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMSC.ru — SMS-код входа (Better Auth phone-number). Логин и пароль из кабинета smsc.ru.
SMSC_LOGIN=
SMSC_PASSWORD=
# Имя отправителя:
#   none                 → без буквенного имени, SMS с цифрового номера (дешёвый тариф, ~2–4 ₽)
#   (пусто / не задано)  → SMSC подставит имя по умолчанию из кабинета (может быть платным)
#   согласованное имя    → используется как есть (должно быть одобрено в кабинете SMSC)
SMSC_SENDER=none
# Текст SMS; подставьте {code} для кода. Латиница → 160 символов и ~в 2 раза дешевле.
SMSC_OTP_MESSAGE=Luxhomme: kod {code}

# ============================================
# PAYMENT
# ============================================
# stripe | yookassa | none
PAYMENT_PROVIDER=none

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ============================================
# CHAT
# ============================================
# intercom | tawkto | custom | none
CHAT_PROVIDER=none
CHAT_API_KEY=

# Tawk.to
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=
NEXT_PUBLIC_TAWKTO_WIDGET_ID=default

# Intercom
NEXT_PUBLIC_INTERCOM_APP_ID=

# ============================================
# EMAIL
# ============================================
# resend | none
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# ============================================
# ANALYTICS
# ============================================
NEXT_PUBLIC_FEATURE_ANALYTICS=false
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=

# ============================================
# REVALIDATION
# ============================================
REVALIDATION_SECRET=

# ============================================
# I18N
# ============================================
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_LOCALES=en,ru

# ============================================
# OZON SELLER API (отзывы и др.) — только сервер
# ============================================
# Кабинет продавца → Настройки → Seller API
OZON_CLIENT_ID=
OZON_SELLER_API_KEY=
